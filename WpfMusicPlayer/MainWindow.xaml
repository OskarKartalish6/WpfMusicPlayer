<Window x:Class="WpfMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfMusicPlayer"
        mc:Ignorable="d"
        Title="WPF Music Player" Height="450" Width="800"
        Background="#FF1E1E1E">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4CAF50"/>
                </Trigger>
            </Style.Triggers>

        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#FF4CAF50"/>
            <Setter Property="Height" Value="25"/>
        </Style>


        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#FF4CAF50"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF4CAF50"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50px"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnTracks" Grid.Column="0"
                        Content="Tracks" FontSize="12" Margin="5,5,5,5"
                        />
                <Button x:Name="btnPlaylist" Grid.Column="1"
                        Content="Playlists" FontSize="12" Margin="5,5,5,5"
                        />
            </Grid>
            <ListBox x:Name="TrackBoxList" Grid.Column="0" Margin="5,0,5,0" Grid.Row="1"/>
        </Grid>


        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50px"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="60"/>

                </Grid.ColumnDefinitions>
                <TextBox x:Name="TextBSearch"
                     VerticalAlignment="Center"
                     TextChanged="TextBox_TextChanged"
                     FontSize="16"
                     Padding="5" Margin="0,0,10,0" Height="36" />
                <TextBlock Text="Search..."
                       Foreground="Gray"
                       Margin="10,0,20,0"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       x:Name="SearchPlaceholder"
                       Visibility="Visible" Height="16"/>
                <Button x:Name="btnAdd"
                        Grid.Column="1"
                    Content="➕"
                    Click="btnAdd_Click"
                    Width="40"
                    HorizontalAlignment="Center"
                    Margin="0,5,0,5" FontSize="14" VerticalAlignment="Center"/>
            </Grid>



            <ListBox x:Name="SearchedTrackBList" Grid.Row="2"/>

            <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,10,0,0">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Label x:Name="lbl_CurrentTime" Content="00:00" Foreground="White" Width="40" Height="26"/>
                    <Label Content="/" Foreground="White" Width="15"/>
                    <Label x:Name="lbl_TotalTime" Content="00:00" Foreground="White" Width="40" Height="26"/>
                </StackPanel>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Slider x:Name="TrackSlider"
                            MaxWidth="400px"
                Maximum="100"
                ValueChanged="TrackSlider_ValueChanged"
                PreviewMouseDown="TrackSlider_PreviewMouseDown"
                PreviewMouseUp="TrackSlider_PreviewMouseUp"
                PreviewMouseLeftButtonDown="TrackSlider_PreviewMouseLeftButtonDown"
                Grid.Column="1" VerticalAlignment="Center" Margin="20,0,20,0" />

                    <Slider x:Name="VolumeSlider"
                            MaxWidth="150px"
                Value="0.5"
                Maximum="1"
                LargeChange="0.1"
                ValueChanged="VolumeSlider_ValueChanged"
                Grid.Column="2" VerticalAlignment="Center" Margin="20,0,20,0" />
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="130" Height="50">
                    <Button x:Name="btnShuffle"
                Content="🔀" 
                Grid.Column="1"
                FontSize="10"
                Click="btnShuffle_Click" Margin="5,10,5,10" Width="30"/>
                    <Button x:Name="btnPlayStop"
                Content="⏵"
                Click="btnPlayStop_CLick"
                Width="40"
                Grid.Column="1"
                HorizontalAlignment="Left" 
                Margin="5,5,5,5"/>
                    <Button x:Name="btnReplay"
                Content="🔁" 
                Grid.Column="1"
                FontSize="10"
                Click="btnReplay_Click" Margin="5,10,5,10" Width="30"/>

                </StackPanel>

            </StackPanel>


        </Grid>
    </Grid>

</Window>